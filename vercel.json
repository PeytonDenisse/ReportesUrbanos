{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist/geo-apoyo-angular/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api-docs",
      "destination": "/api/index.js"
    },
    {
      "source": "/api-docs/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api-docs.json",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}